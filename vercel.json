{
  "cleanUrls": true,
  "trailingSlash": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "tdm-reservation",
          "value": "1"
        },
        {
          "key": "tdm-policy",
          "value": "https://energygrowthplaybook.com/terms/"
        },
        {
          "key": "X-Robots-Tag",
          "value": "index, follow, max-image-preview:large, max-snippet:-1"
        }
      ]
    }
  ]
}